# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริงจาก Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# LIFF ID (เว็บฝั่งผู้ซื้อ/ผู้ขาย เปิดผ่าน LINE)
NEXT_PUBLIC_LIFF_ID=2010610601-jLbdWAiK

# ── ความปลอดภัย (ตั้งใน Vercel ฝั่ง server เท่านั้น — ห้ามขึ้นต้น NEXT_PUBLIC_) ──
# เปิดโหมด verify LINE idToken ฝั่ง server (กันปลอม userId/ยึดบัญชี)
# LINE_CHANNEL_ID = Channel ID ของ LINE Login channel ที่ LIFF นี้สังกัด (จาก LINE Developers)
LINE_CHANNEL_ID=
# LINE_AUTH_SECRET = string สุ่มยาว ๆ (เช่น `openssl rand -hex 32`) ใช้ derive รหัสผ่านฝั่ง server
LINE_AUTH_SECRET=

# บังคับผ่านการยืนยันตัวตน (status=active) ก่อนเข้าฝั่งซื้อ — ตั้ง "true" เพื่อเปิดใช้ production
# (ค่าเริ่มต้น=ปิด เพื่อไม่ล็อกผู้ใช้เดโม)
REQUIRE_BUYER_VERIFIED=false

# (ยังไม่ใช้ตอนนี้ — สำหรับ payment gateway จริง เช่น Omise/GB Prime Pay)
# OMISE_SECRET_KEY=
# OMISE_WEBHOOK_SECRET=
# SUPABASE_SERVICE_ROLE_KEY=   # ฝั่ง server เท่านั้น (mint session/แอดมิน) — ห้ามหลุด client
